# 可选：真实 DeepSeek Key。API 留空时仍可只读启动并查看已有数据，但不能创建新分析任务；worker 启动前必须设置。
NOVEL_EVAL_DEEPSEEK_API_KEY=

# 已弃用：API 不再使用该变量控制启动成功；缺少 Key 时允许只读启动。
NOVEL_EVAL_REQUIRE_REAL_PROVIDER=0

# API / Web 端口
NOVEL_EVAL_API_HOST=127.0.0.1
NOVEL_EVAL_API_PORT=8000
NOVEL_EVAL_WEB_PORT=3000

# 本地持久化与日志
NOVEL_EVAL_DB_PATH=./var/novel-evaluation.sqlite3
NOVEL_EVAL_LOG_DIR=./var/logs
NOVEL_EVAL_PROMPTS_DIR=./prompts
